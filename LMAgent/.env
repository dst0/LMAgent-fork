# ─────────────────────────────────────────────
#  LMAgent — Environment Variables
#  Fill in what you need, leave the rest blank
# ─────────────────────────────────────────────


# ── AGENT (required) ──────────────────────────
# PIN shown in console on startup (leave blank to auto-generate one)
AGENT_TOKEN=

# Port to run the web UI on (default: 7860)
AGENT_PORT=7860

# Host to bind to (default: 0.0.0.0 = all interfaces)
AGENT_HOST=0.0.0.0


# ── DISCORD ───────────────────────────────────
# Get this from: discord.com/developers/applications
# → Your App → Bot tab → Reset Token
# NOTE: this is the Bot Token, NOT the public key
DISCORD_TOKEN=


# ── TELEGRAM ──────────────────────────────────
# Get this by messaging @BotFather on Telegram → /newbot
TELEGRAM_TOKEN=


# ── WHATSAPP (Green API) ───────────────────────
# Sign up at green-api.com, scan QR, then copy from your instance dashboard
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=


# ── SMS (Twilio) ───────────────────────────────
# Get from: console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1xxxxxxxxxx


# ── SSL (optional — leave blank for plain HTTP) ─
AGENT_CERT=
AGENT_KEY=
